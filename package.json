{
  "name": "rtmf1m-build-tools-2026",
  "version": "1.0.0",
  "description": "Git basics and build pipeline NPM scripts",
  "main": "index.js",
  "browserslist": "> 0.5%, not dead",
  "scripts": {
    "clear": "rimraf \"./dist/\"",
    "server": "browser-sync start --server \"./\" --files \"*.html\" \"./dist/**/*\"",
    "copy:fonts": "copyfiles -u 1 \"./src/assets/fonts/*\" \"./dist/\"",
    "styles:dev": "lightningcss --bundle --browserslist \"./src/assets/css/main.css\" -o \"./dist/assets/css/main.bundle.css\"",
    "styles:prod": "lightningcss --bundle --minify --browserslist \"./src/assets/css/main.css\" -o \"./dist/assets/css/main.bundle.css\"",
    "scripts:dev": "esbuild \"./src/assets/js/main.js\" --target=\"es2020\" --bundle --outfile=\"./dist/assets/js/main.bundle.js\"",
    "scripts:prod": "esbuild \"./src/assets/js/main.js\" --target=\"es2020\" --bundle --minify --outfile=\"./dist/assets/js/main.bundle.js\"",
    "watch:styles": "onchange \"./src/assets/css/**/*\" -- npm run styles:dev",
    "watch:scripts": "onchange \"./src/assets/js/**/*\" -- npm run scripts:dev",
    "build": "npm-run-all clear --parallel styles:prod scripts:prod copy:fonts",
    "dev": "npm-run-all --parallel server watch:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeromecoupe/rtmf1m-build-tools-2026.git"
  },
  "keywords": [
    "npm",
    "scripts",
    "git",
    "build pipeline"
  ],
  "author": "Nox Nguyen",
  "contributors": [
    "Jérôme Coupé",
    "Nox Nguyen"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jeromecoupe/rtmf1m-build-tools-2026/issues"
  },
  "homepage": "https://github.com/jeromecoupe/rtmf1m-build-tools-2026#readme",
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "esbuild": "^0.27.3",
    "lightningcss-cli": "^1.31.1",
    "npm-run-all": "^4.1.5",
    "onchange": "^7.1.0",
    "rimraf": "^6.1.2"
  },
  "dependencies": {
    "copyfiles": "^2.4.1"
  }
}
